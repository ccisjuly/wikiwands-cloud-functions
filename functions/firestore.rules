rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function owner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ---------- Job Application 数据结构 ----------

    // 用户档案：仅本人读写
    match /users/{uid} {
      allow read, write: if owner(uid);
    }

    // 简历：仅本人读写
    match /users/{uid}/resumes/{resumeId} {
      allow read, write: if owner(uid);
    }

    // 简历分析：仅本人读写（后端可写，客户端可读/创建占位）
    match /users/{uid}/resumeAnalyses/{analysisId} {
      allow read, write: if owner(uid);
    }

    // 简历改进建议：仅本人读写
    match /users/{uid}/resumeSuggestions/{suggestionId} {
      allow read, write: if owner(uid);
    }

    // 申请记录：仅本人读写
    match /users/{uid}/applications/{applicationId} {
      allow read, write: if owner(uid);
    }

    // 生成素材（求职信等）：仅本人读写
    match /users/{uid}/generatedAssets/{assetId} {
      allow read, write: if owner(uid);
    }

    // 定制简历（按职位描述生成的简历版本）：仅本人读写
    match /users/{uid}/customizedResumes/{resumeId} {
      allow read, write: if owner(uid);
    }

    // 职位：已登录可读，仅后端/Admin 可写
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
